# ── Dependencies (always re-installed inside container) ────────────────────────
node_modules

# ── Next.js build output ───────────────────────────────────────────────────────
.next
.turbo
out
dist
build

# ── Large source assets not needed in build context ───────────────────────────
# icon-source.png is 408KB — icons are generated locally, not during Docker build
public/icon-source.png

# ── Git ────────────────────────────────────────────────────────────────────────
.git
.gitignore
.github

# ── Env files – NEVER bake secrets into the image ─────────────────────────────
.env
.env.*
!.env.example

# ── Editor / OS ───────────────────────────────────────────────────────────────
.DS_Store
.vscode
.idea
*.pem
*.log

# ── Docker itself ─────────────────────────────────────────────────────────────
Dockerfile
.dockerignore
docker-compose*.yml

# ── Docs / local scripts ──────────────────────────────────────────────────────
README*.md
DEPLOYMENT*.md
DOCKER_EXPLAINED*.md
PWA_GUIDE*.md
scripts/
